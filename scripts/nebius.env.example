# Copy this file to .env.nebius and edit values for the current VM.
# .env.nebius is ignored by git through the existing .env.* rule.

NEBIUS_HOST=203.0.113.10
NEBIUS_USER=ubuntu
NEBIUS_PORT=22
NEBIUS_SSH_KEY=$HOME/.ssh/nebius

# Remote path is relative to the SSH user's home unless you use an absolute path.
NEBIUS_REMOTE_DIR=lm-arch-ht4

# Execution mode:
# - jupyter: use the already-configured Jupyter/Python environment on the VM
# - host: create/use a remote .venv in NEBIUS_REMOTE_DIR
NEBIUS_EXEC_MODE=jupyter

# Python executable from the existing Jupyter environment.
# If the VM needs activation first, set NEBIUS_JUPYTER_PYTHON to the full path,
# for example /home/khab1973/miniconda3/envs/myenv/bin/python.
NEBIUS_JUPYTER_PYTHON=python

# Remote virtual environment created inside NEBIUS_REMOTE_DIR.
# Used only when NEBIUS_EXEC_MODE=host.
NEBIUS_REMOTE_VENV=.venv
